#!/usr/bin/env python3
"""library-pm-pollution-scan — find (and optionally delete) stale test artefacts.

Scans Jira for tickets and projects left behind by integration tests:
  * tickets whose summary matches INTEGRATION-TEST or DELETE-ME and are >24h old
  * projects whose key matches ZZT* or whose name contains
    INTEGRATION-TEST / DELETE-ME

By default the tool is READ-ONLY (--dry-run). --execute requires interactive
confirmation before any delete is performed. NEVER deletes without human
sign-off. See TESTING-STANDARD.md §4.

Usage:
    JIRA_EMAIL=... JIRA_API_TOKEN=... bin/library-pm-pollution-scan
    JIRA_EMAIL=... JIRA_API_TOKEN=... bin/library-pm-pollution-scan --execute
"""

from __future__ import annotations

import argparse
import asyncio
import os
import sys
from dataclasses import dataclass
from typing import Any

# Make the src/ layout importable when run straight from the worktree.
_HERE = os.path.dirname(os.path.abspath(__file__))
_SRC = os.path.abspath(os.path.join(_HERE, "..", "src"))
if _SRC not in sys.path:
    sys.path.insert(0, _SRC)

from library_server.pm.jira_client import JiraApiError, JiraClient  # noqa: E402


SITE_URL = os.environ.get("JIRA_SITE_URL", "https://sevenbelow.atlassian.net")

# JQL: cast a wide net on summary text; we narrow client-side so JQL's fuzzy
# `~` operator doesn't scoop up real tickets that merely mention the phrase
# (e.g. LIBRARY-7 "Fix integration-test cleanup"). The 24h age filter is
# optional and applied client-side so callers can purge same-session garbage.
POLLUTION_JQL = '(summary ~ "INTEGRATION-TEST" OR summary ~ "DELETE-ME")'

# Client-side precision filter: the summary must START with one of these
# markers (optionally followed by a suffix). Real in-flight tickets that
# merely reference the marker as substring are excluded.
_POLLUTION_PREFIXES = (
    "INTEGRATION-TEST-DELETE-ME",
    "INTEGRATION-TEST-LINK-A",
    "INTEGRATION-TEST-LINK-B",
    "INTEGRATION-TEST ",  # trailing space — standalone token, not "integration-test cleanup"
    "DELETE-ME ",
)


def _is_polluted_summary(summary: str) -> bool:
    """Precision match: summary must START with a pollution marker.

    Matches ``INTEGRATION-TEST-DELETE-ME xxxx`` (literal prefix) but NOT
    ``Fix integration-test cleanup`` (real ticket, marker as substring).
    """
    up = summary.strip().upper()
    return any(up.startswith(p) for p in _POLLUTION_PREFIXES)


@dataclass
class PollutionReport:
    tickets: list[dict[str, Any]]
    projects: list[dict[str, Any]]

    @property
    def ticket_count(self) -> int:
        return len(self.tickets)

    @property
    def project_count(self) -> int:
        return len(self.projects)


def _is_polluted_project(project: dict[str, Any]) -> bool:
    """Return True iff this project matches the pollution markers."""
    key = project.get("key", "")
    name = project.get("name", "")
    if key.startswith("ZZT"):
        return True
    upper_name = name.upper()
    if "INTEGRATION-TEST" in upper_name or "DELETE-ME" in upper_name:
        return True
    return False


def filter_polluted_projects(projects_response: dict[str, Any]) -> list[dict[str, Any]]:
    """Pure filter, easily unit-tested against fixture JSON."""
    values = projects_response.get("values", [])
    return [p for p in values if _is_polluted_project(p)]


def filter_polluted_issues(search_response: dict[str, Any]) -> list[dict[str, Any]]:
    """Return only issues whose summary starts with a pollution marker.

    JQL's ``summary ~`` is fuzzy and matches substrings, so real tickets like
    ``Fix integration-test cleanup`` come back in the server response. This
    filter applies the precision check client-side so we never delete real
    work tickets even when the broad JQL pulls them.
    """
    issues = search_response.get("issues", [])
    return [
        i for i in issues
        if _is_polluted_summary(i.get("fields", {}).get("summary", ""))
    ]


async def scan(client: JiraClient, *, min_age_hours: int = 0) -> PollutionReport:
    """Run both queries and assemble a report.

    ``min_age_hours`` = 0 (default) purges same-session garbage; callers that
    want a safety buffer can pass e.g. 24.
    """
    jql = POLLUTION_JQL
    if min_age_hours > 0:
        jql = f"{POLLUTION_JQL} AND created < -{min_age_hours}h"
    # Paginate via nextPageToken — Jira's /search/jql endpoint ignores start_at.
    all_issues: list[dict[str, Any]] = []
    next_token: str | None = None
    while True:
        page = await client.search_issues(
            jql=jql, max_results=100, next_page_token=next_token
        )
        issues = page.get("issues", [])
        all_issues.extend(issues)
        next_token = page.get("nextPageToken")
        if not next_token or not issues:
            break
    tickets = filter_polluted_issues({"issues": all_issues})

    # list_projects returns at most 50 per page; iterate.
    all_projects: list[dict[str, Any]] = []
    start_at = 0
    while True:
        page = await client.list_projects(max_results=50, start_at=start_at)
        vals = page.get("values", [])
        all_projects.extend(vals)
        if len(vals) < 50:
            break
        start_at += 50
    projects = filter_polluted_projects({"values": all_projects})

    return PollutionReport(tickets=tickets, projects=projects)


def _print_report(report: PollutionReport) -> None:
    print(f"\nPollution scan result (site: {SITE_URL})")
    print(f"  Tickets matching pollution markers: {report.ticket_count}")
    print(f"  Projects matching pollution markers: {report.project_count}")
    if report.tickets:
        print("\n  Tickets:")
        for t in report.tickets:
            key = t.get("key", "?")
            summary = t.get("fields", {}).get("summary", "?")
            print(f"    - {key}: {summary}")
    if report.projects:
        print("\n  Projects:")
        for p in report.projects:
            print(f"    - {p.get('key', '?')}: {p.get('name', '?')}")


async def _purge(client: JiraClient, report: PollutionReport) -> tuple[int, list[str]]:
    """Delete every reported artefact. Returns (n_deleted, failures)."""
    deleted = 0
    failures: list[str] = []
    for t in report.tickets:
        key = t.get("key", "")
        if not key:
            continue
        try:
            await client.delete_issue(key)
            deleted += 1
            print(f"  deleted issue {key}")
        except JiraApiError as e:
            if e.status_code == 404:
                continue
            failures.append(f"issue {key}: {e}")
    for p in report.projects:
        pkey = p.get("key", "")
        if not pkey:
            continue
        try:
            await client.delete_project(pkey)
            deleted += 1
            print(f"  deleted project {pkey}")
        except JiraApiError as e:
            if e.status_code == 404:
                continue
            failures.append(f"project {pkey}: {e}")
    return deleted, failures


async def _amain(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--execute",
        action="store_true",
        help="Actually delete (requires interactive confirmation). Default is dry-run.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Explicit dry-run (default behaviour; kept for clarity).",
    )
    parser.add_argument(
        "--yes",
        action="store_true",
        help="Skip interactive stdin prompt — requires --confirm-count=N "
        "matching the scan's exact ticket+project count, so you cannot "
        "accidentally purge more than you expected. Reserved for CI "
        "environments and Claude workflows that can't hold a TTY.",
    )
    parser.add_argument(
        "--confirm-count",
        type=int,
        default=None,
        help="Exact expected count (tickets + projects). When combined with "
        "--yes, the purge refuses unless the scan returns this exact count.",
    )
    parser.add_argument(
        "--max-deletions",
        type=int,
        default=500,
        help="Hard ceiling on deletions in a single run (default 500). "
        "Scan above the ceiling aborts — re-scope before re-running.",
    )
    args = parser.parse_args(argv)

    if not (os.environ.get("JIRA_EMAIL") and os.environ.get("JIRA_API_TOKEN")):
        print("error: JIRA_EMAIL and JIRA_API_TOKEN must be set.", file=sys.stderr)
        return 2

    client = JiraClient(site_url=SITE_URL, timeout=30.0)
    report = await scan(client)
    _print_report(report)

    if not args.execute:
        print("\n[dry-run] No deletions performed. Re-run with --execute to purge.")
        return 0

    if report.ticket_count == 0 and report.project_count == 0:
        print("\nNothing to delete.")
        return 0

    total = report.ticket_count + report.project_count

    if total > args.max_deletions:
        print(
            f"\nERROR: scan would delete {total} items, above --max-deletions "
            f"ceiling of {args.max_deletions}. Narrow the filter or raise the "
            f"ceiling explicitly.",
            file=sys.stderr,
        )
        return 2

    print("\n*** DESTRUCTIVE ACTION ***")
    print(f"About to delete: {report.ticket_count} tickets, {report.project_count} projects.")
    print("Full report shown above — review before confirming.")

    if args.yes:
        # CI / non-interactive path: require --confirm-count to match exactly.
        if args.confirm_count is None:
            print(
                "\nERROR: --yes requires --confirm-count=N. The count must equal "
                f"{total} (current scan total). This prevents accidental "
                "purges when the scan returns more tickets than expected.",
                file=sys.stderr,
            )
            return 2
        if args.confirm_count != total:
            print(
                f"\nERROR: --confirm-count={args.confirm_count} does not match "
                f"current scan total {total}. Re-run --dry-run, review, then "
                f"pass --confirm-count={total}.",
                file=sys.stderr,
            )
            return 2
        print(f"[--yes] confirm-count matches ({total}). Proceeding.")
    else:
        # Interactive path: require typed phrase.
        expected = f"DELETE {report.ticket_count} tickets and {report.project_count} projects"
        print(f"\nType '{expected}' to confirm:")
        got = input("> ").strip()
        if got != expected:
            print("Confirmation did not match. Aborting.")
            return 1

    deleted, failures = await _purge(client, report)
    print(f"\nDeleted: {deleted}")
    if failures:
        print(f"Failures: {len(failures)}")
        for f in failures:
            print(f"  - {f}")
        return 1
    return 0


def main(argv: list[str] | None = None) -> int:
    return asyncio.run(_amain(argv if argv is not None else sys.argv[1:]))


if __name__ == "__main__":
    sys.exit(main())
